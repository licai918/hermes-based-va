# Dependencies
node_modules/

# Environment and secrets
.env
.env.*
!.env.example
*.pem
credentials.json

# OS and editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Build and cache
dist/
build/
.cache/
.scratch/

# Next.js (apps/workbench)
.next/
out/
next-env.d.ts
*.tsbuildinfo
.turbo/

# Launch Eval run artifacts (ADR-0074); reports are generated per run
eval/reports/

# Python (hermes/ uv project)
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/

# Hermes profile runtime state (generated by a booted agent: credential pool,
# session transcripts, caches). Never commit — auth.json references live keys.
hermes/profiles/*/auth.json
hermes/profiles/*/auth.lock
hermes/profiles/*/cache/
hermes/profiles/*/logs/
hermes/profiles/*/sessions/
hermes/profiles/*/memories/
hermes/profiles/*/audio_cache/
hermes/profiles/*/image_cache/
