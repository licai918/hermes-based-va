# Local Hermes Gateway env template (copy to .env; gitignored).
# Full variable list: see ../.env.example (Gateway section).

# Optional. ngrok authtoken for exposing http://127.0.0.1:8080 to SimpleTexting webhooks.
# Get yours: https://dashboard.ngrok.com/get-started/your-authtoken
# Then from repo root: pwsh scripts/start-ngrok-tunnel.ps1
NGROK_AUTHTOKEN=

# Composio (when INTEGRATION_DRIVER=composio). See docs/ops/composio-connected-accounts.md
# This file is the source of truth for EVERY tool-executing process: docker-compose
# passes it to the gateway, both dispatch servers, and both workers (0.0.4 S12).
# INTEGRATION_DRIVER=composio
# COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=
# COMPOSIO_SHOPIFY_CONNECTED_ACCOUNT_ID=
# COMPOSIO_QBO_CONNECTED_ACCOUNT_ID=
# COMPOSIO_SQUARE_CONNECTED_ACCOUNT_ID=
# REQUIRED pin per configured toolkit -- every process refuses to BOOT without it
# (require_composio_configuration, S12 fix wave 1).
# Shopify pin evidence, re-verified live 2026-07-22: 20260506_00 exposes
# SHOPIFY_GET_CUSTOMERS_SEARCH (the ingress phone match) and SHOPIFY_LIST_CUSTOMERS
# (its scan fallback). Both are probed by composio_smoke phase 2.
# COMPOSIO_TOOLKIT_VERSION_SHOPIFY=20260506_00
# COMPOSIO_TOOLKIT_VERSION_QUICKBOOKS=20260623_00
# COMPOSIO_TOOLKIT_VERSION_SQUARE=20260616_00
# Deadline in ms for ONE tool call, divided across the SDK's three HTTP requests.
# COMPOSIO_DEADLINE_MS=8000
# SMOKE_SHOPIFY_CUSTOMER_ID=gid://shopify/Customer/
