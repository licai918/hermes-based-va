# Hermes VA — local development environment example.
# Copy to .env (or a per-service .env.local, ADR-0098) and fill in real values.
# Never commit real secrets (see .gitignore). Local development defaults to mock
# integrations and runs without Docker (ADR-0137); deployed envs inject these from
# GCP Secret Manager into Cloud Run (see docs/ops/deploy-cloud-run.md).

# Integration driver for Domain Adapter Tools: mock | composio
# Defaults to "mock" when unset (ADR-0132, ADR-0137). Any other value raises at
# boot -- the speculative "rest" value was deleted in 0.0.4 S12 (FR-21).
INTEGRATION_DRIVER=mock

# ============================================================================
# Datastore — Toee Business Datastore system-of-record (ADR-0140, ADR-0142).
# Local-first: `docker compose up -d postgres` then apply schema with
# `uv run python -m hermes_runtime.datastore.migrate` (run in hermes-runtime/).
# Defaults to the docker-compose Postgres when unset; deployed envs inject the
# Cloud SQL DSN from Secret Manager (same URL shape).
# ============================================================================

# DATABASE_URL=postgresql://toee:toee@localhost:5432/toee_va

# Toee Knowledge Store (FR-1, PRD §7.4) -- SEPARATE database from toee_va
# (S-ISO). Apply schema with `uv run python -m hermes_runtime.knowledge.migrate`
# (run in hermes-runtime/); it self-provisions toee_knowledge if missing.
# Defaults to the docker-compose Postgres when unset.
# KNOWLEDGE_DATABASE_URL=postgresql://toee:toee@localhost:5432/toee_knowledge

# Dispatch backend for the internal system-of-record tools (tools:dispatch,
# ADR-0141): mock | datastore. Mock-first (ADR-0137) — defaults to "mock" so an
# unconfigured app runs without Postgres. Set "datastore" to back toee_case,
# toee_workbench_read, toee_workbench_admin, toee_knowledge_ops, toee_eval_review,
# toee_customer_memory, and toee_identity_lookup with Postgres (ADR-0140). This is
# a separate axis from INTEGRATION_DRIVER (the external-vendor backend).
# TOOL_BACKEND=mock

# ============================================================================
# Per-profile tool-dispatch servers (ADR-0141, ADR-0142 local-first; Slice 34).
# One process per profile, each with its own profile selector + bearer token +
# port, serving POST /v1/tools:dispatch + GET /healthz for the workbench BFF.
# build_tool_dispatch_app fails closed at boot if either var below is missing.
# `pnpm dev` runs BOTH servers as docker compose services (8091 copilot, 8092
# admin) and derives each DISPATCH_API_TOKEN from apps/workbench/.env.local, so
# you do not normally set these by hand. See apps/workbench/README.md and
# docs/ops/local-dispatch-servers.md.
# ============================================================================

# Required (per server). Profile this process runs under: customer_service_external
# | internal_copilot | supervisor_admin (ADR-0034/0035/0038).
# TOEE_HERMES_PROFILE=internal_copilot
# Required (per server). Bearer the BFF must present; pair with the matching
# HERMES_*_API_TOKEN below. Use a distinct value per profile.
# DISPATCH_API_TOKEN=

# ============================================================================
# Gateway — Python FastAPI runtime (hermes-runtime/) -> Cloud Run toee-hermes-gateway
# build_gateway_app fails closed at boot if any *required* var below is missing
# (ADR-0095/0106/0107). Names are exactly what the runtime reads.
# ============================================================================

# Required. Shared secret token in the registered SimpleTexting webhook URL
# (ADR-0153: SimpleTexting does not sign payloads — the gateway route is
# /webhooks/simpletexting?token=<this value>). Generate a long random string.
# SIMPLETEXTING_WEBHOOK_TOKEN=
# Required. Shared secret guarding the internal agent-turn route (ADR-0106).
# INTERNAL_JOB_SECRET=
# Required. SimpleTexting API v2 bearer token for outbound sends (ADR-0083).
# SIMPLETEXTING_API_TOKEN=
# Optional. Sending number on the SimpleTexting account; defaults to the
# account's primary number when unset.
# SIMPLETEXTING_ACCOUNT_PHONE=9053378266
# Optional. SimpleTexting REST base URL; defaults to https://api-app2.simpletexting.com/v2/
# SIMPLETEXTING_API_BASE_URL=

# Required. OpenRouter API key for the async agent turn (ADR-0009).
# OPENROUTER_API_KEY=
# When set to "datastore", the SMS gateway persists inbound messages to the same
# Postgres Workbench reads (Tier B). Requires local Postgres + migrations.
# REQUIRED on any deployed revision: the in-memory store dedups per process, and
# messageId dedup is the only replay protection SimpleTexting allows, so
# build_gateway_app refuses to boot without it when DEPLOY_ENVIRONMENT is set
# (ADR-0153).
# TOOL_BACKEND=datastore
# Deployment marker: production | staging. Leave unset for local development.
# DEPLOY_ENVIRONMENT=
# Optional. OpenRouter base URL; defaults to https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=
# Optional. Primary model; defaults to deepseek/deepseek-v4-pro (ADR-0009).
# OPENROUTER_MODEL=
# Optional. Fallback model on retryable errors; defaults to qwen/qwen3.6-flash.
# OPENROUTER_FALLBACK_MODEL=

# ============================================================================
# Composio — only required when INTEGRATION_DRIVER=composio (ADR-0129/0137).
# Canonical names per docs/ops/composio-connected-accounts.md; the link-time
# *_AUTH_CONFIG_ID vars live in that runbook, not here.
# ============================================================================

# COMPOSIO_API_KEY=  # secret; env only, never committed (NFR-6)
# COMPOSIO_USER_ID=
# COMPOSIO_SHOPIFY_CONNECTED_ACCOUNT_ID=
# COMPOSIO_QBO_CONNECTED_ACCOUNT_ID=
# COMPOSIO_SQUARE_CONNECTED_ACCOUNT_ID=
#
# REQUIRED toolkit version pins, one per CONFIGURED toolkit (0.0.4 S12, FR-18).
# Not optional any more: unpinned, the SDK resolves "latest" and then raises
# ToolVersionRequiredError from inside a customer's turn. build_composio_driver()
# now fails closed at boot naming the missing variable instead.
#
# Keyed by COMPOSIO's toolkit slug, not ours -- QuickBooks is QUICKBOOKS here
# even though the connected-account variable above says QBO. Values below are
# the versions verified live by `python -m hermes_runtime.composio_smoke`.
#
# Shopify pin evidence (re-verified live 2026-07-22, S12 fix wave 1): 20260506_00
# exposes SHOPIFY_GET_CUSTOMERS_SEARCH -- the action the gateway's ingress phone
# match uses, and the reason its catalog-scan fallback does not fire. The same
# probe found SHOPIFY_GET_ALL_CUSTOMERS does NOT exist at this pin; that fallback
# now uses SHOPIFY_LIST_CUSTOMERS. Both slugs are probed by the smoke's phase 2,
# so a pin bump that drops either FAILS the smoke instead of the ack path.
COMPOSIO_TOOLKIT_VERSION_SHOPIFY=20260506_00
COMPOSIO_TOOLKIT_VERSION_QUICKBOOKS=20260623_00
COMPOSIO_TOOLKIT_VERSION_SQUARE=20260616_00
# Backend deadline in ms for ONE tool call (NFR-8). Defaults to 8000, divided
# across the three HTTP requests the SDK makes per call. The SDK's own default
# is 60s with retries, which outlives the turn it is serving.
# COMPOSIO_DEADLINE_MS=8000
# The PAC-6 test customer's Shopify gid. Read ONLY by composio_smoke, so the
# smoke's happy path runs against a test entity, never a real customer's orders.
# SMOKE_SHOPIFY_CUSTOMER_ID=gid://shopify/Customer/

# ============================================================================
# Gadget attribution bridge — QBO customer-scoped reads (0.0.4 S27, ADR-0157).
# Reads the owner's paymentstatussync `qboCustomerMapping` model to join a live
# QBO invoice's CustomerRef to the verified Shopify customer. Owner-blocked, like
# the EasyRoutes token: unset -> QBO customer-scoped reads (list_customer_invoices,
# get_invoice, and S13's AR summary) fail closed per call; Shopify/Square/etc.
# keep serving. NOT a boot gate.
# ============================================================================

# GADGET_API_KEY=  # secret (HERMES_MAPPING_SECRET on the Gadget app); env only,
#   never committed (NFR-6). Sent as `Authorization: Bearer <key>` to the endpoint.
# GADGET_API_URL=https://paymentstatussync.gadget.app  # ORIGIN only; the route path is
#   appended in code. DEFAULTS to this production origin — set to the
#   `--development` origin (https://paymentstatussync--development.gadget.app) for wire-tests.
# GADGET_DEADLINE_MS=8000  # per-CALL wall-clock bound (NFR-8), matches Composio

# ============================================================================
# Workbench — Next.js app (apps/workbench) -> Cloud Run toee-hermes-workbench
# ============================================================================

# Required. Session signing secret for local username/password auth (ADR-0017).
# WORKBENCH_SESSION_SECRET=

# REQUIRED (all four). Per-profile Hermes API base URL + bearer token the BFF calls
# over HTTP for resource routes (deterministic POST /v1/tools:dispatch, ADR-0141).
# /api/copilot/* uses the copilot pair; /api/admin/* and /api/auth/login use the
# admin pair (login authenticates against the same Postgres accounts the admin API
# manages, ADR-0144). Local ports: copilot 8091, admin 8092.
#
# The workbench is API-only as of 0.0.4 S09: there is no in-memory fallback, and it
# refuses to boot without these, naming whichever are missing. They live in
# apps/workbench/.env.local, which is the SOURCE OF TRUTH: `pnpm dev` reads the
# tokens from there and hands them to each dispatch server as its
# DISPATCH_API_TOKEN, so the two cannot drift. `pnpm dev` writes the file with
# these dev defaults if it is missing -- see apps/workbench/README.md.
# HERMES_COPILOT_API_URL=http://127.0.0.1:8091
# HERMES_COPILOT_API_TOKEN=dev-copilot-token
# HERMES_ADMIN_API_URL=http://127.0.0.1:8092
# HERMES_ADMIN_API_TOKEN=dev-admin-token

# Simulator -> gateway (apps/workbench/.env.local too). SIMPLETEXTING_WEBHOOK_TOKEN
# is shared with the gateway by `pnpm dev`; a mismatch is a 401 on every simulated
# inbound.
# SIMULATOR_GATEWAY_URL=http://127.0.0.1:8080
# SIMPLETEXTING_WEBHOOK_TOKEN=dev-webhook-token
