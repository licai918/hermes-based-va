# Hermes VA — local development environment example.
# Copy to .env and fill in real values. Never commit .env (see .gitignore).
#
# Local development defaults to mock integrations and runs without Docker
# (ADR-0137: local-dev mock default, optional Composio).

# Integration driver for Domain Adapter Tools: mock | composio | rest
# Defaults to "mock" when unset (ADR-0132, ADR-0137).
INTEGRATION_DRIVER=mock

# --- Composio (only required when INTEGRATION_DRIVER=composio) ---
# Stored in GCP Secret Manager in deployed environments (ADR-0129).
# COMPOSIO_API_KEY=
# Non-secret connected-account identifiers used by Layer 1 adapters (ADR-0129).
# COMPOSIO_USER_ID=
# COMPOSIO_CONNECTED_ACCOUNT_ID=

# --- Textline channel (services/hermes-gateway) ---
# Webhook signature secret for inbound verification (ADR-0021).
# TEXTLINE_WEBHOOK_SECRET=

# --- Workbench auth (apps/workbench) ---
# Session signing secret for local username/password auth (ADR-0017).
# WORKBENCH_SESSION_SECRET=
