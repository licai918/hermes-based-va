# Hermes VA — local development environment example.
# Copy to .env (or a per-service .env.local, ADR-0098) and fill in real values.
# Never commit real secrets (see .gitignore). Local development defaults to mock
# integrations and runs without Docker (ADR-0137); deployed envs inject these from
# GCP Secret Manager into Cloud Run (see docs/ops/deploy-cloud-run.md).

# Integration driver for Domain Adapter Tools: mock | composio | rest
# Defaults to "mock" when unset (ADR-0132, ADR-0137).
INTEGRATION_DRIVER=mock

# ============================================================================
# Gateway — Python FastAPI runtime (hermes-runtime/) -> Cloud Run toee-hermes-gateway
# build_gateway_app fails closed at boot if any *required* var below is missing
# (ADR-0095/0106/0107). Names are exactly what the runtime reads.
# ============================================================================

# Required. Inbound Textline webhook HMAC-SHA256 signing secret (ADR-0021).
# TEXTLINE_WEBHOOK_SECRET=
# Required. Shared secret guarding the internal agent-turn route (ADR-0106).
# INTERNAL_JOB_SECRET=
# Required. Textline Developer API access token for outbound replies (ADR-0083).
# TEXTLINE_ACCESS_TOKEN=
# Optional. Textline REST base URL; defaults to https://application.textline.com/
# TEXTLINE_API_BASE_URL=

# Required. OpenRouter API key for the async agent turn (ADR-0009).
# OPENROUTER_API_KEY=
# Optional. OpenRouter base URL; defaults to https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=
# Optional. Primary model; defaults to deepseek/deepseek-v4-pro (ADR-0009).
# OPENROUTER_MODEL=
# Optional. Fallback model on retryable errors; defaults to qwen/qwen3.6-flash.
# OPENROUTER_FALLBACK_MODEL=

# ============================================================================
# Composio — only required when INTEGRATION_DRIVER=composio (ADR-0129/0137).
# Canonical names per docs/ops/composio-connected-accounts.md; the link-time
# *_AUTH_CONFIG_ID vars live in that runbook, not here.
# ============================================================================

# COMPOSIO_API_KEY=  # secret; optional until integration phase (issue #33)
# COMPOSIO_USER_ID=
# COMPOSIO_SHOPIFY_CONNECTED_ACCOUNT_ID=
# COMPOSIO_QBO_CONNECTED_ACCOUNT_ID=
# COMPOSIO_SQUARE_CONNECTED_ACCOUNT_ID=

# ============================================================================
# Workbench — Next.js app (apps/workbench) -> Cloud Run toee-hermes-workbench
# ============================================================================

# Required. Session signing secret for local username/password auth (ADR-0017).
# WORKBENCH_SESSION_SECRET=

# Optional. Per-profile Hermes API base URL + bearer token the BFF calls over HTTP
# for resource routes (deterministic POST /v1/tools:dispatch, ADR-0141). When a
# pair is unset the BFF falls back to the in-memory store, so local dev and tests
# run without the backend. /api/copilot/* uses the copilot pair, /api/admin/* the
# admin pair (route-derived profile, ADR-0093).
# HERMES_COPILOT_API_URL=
# HERMES_COPILOT_API_TOKEN=
# HERMES_ADMIN_API_URL=
# HERMES_ADMIN_API_TOKEN=
